.env.*
!.env.example

# ── Logs e temporários ────────────────────────────────────────
*.log
npm-debug.log*
.npm

# ── Testes e documentação ─────────────────────────────────────
*.test.js
*.spec.js
coverage
__tests__

# ── IDE e SO ──────────────────────────────────────────────────
.vscode
.idea
*.DS_Store
Thumbs.db
