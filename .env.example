# ============================================================
# .env.example — Variáveis de ambiente para docker-compose
# Copie para .env e preencha os valores
# ============================================================

# Banco de dados
POSTGRES_USER=vincelo
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=vincelo

# JWT (use strings longas e aleatórias em produção)
JWT_SECRET=troque_por_string_aleatoria_longa_aqui
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ALLOWED_ORIGINS=https://seu-dominio.com

# API URL (usada pelo frontend)
NEXT_PUBLIC_API_URL=https://api.seu-dominio.com/api

# Stripe (pagamentos)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# AWS S3 (armazenamento de arquivos)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_BUCKET_NAME=vincelo-uploads
AWS_REGION=us-east-1

# Email (Nodemailer)
MAIL_HOST=smtp.seu-provedor.com
MAIL_PORT=587
MAIL_USER=noreply@seu-dominio.com
MAIL_PASS=senha_do_email
