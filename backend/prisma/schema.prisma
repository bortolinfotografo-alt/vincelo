generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  password         String?
  googleId         String?             @unique
  role             UserRole            @default(FREELANCER)
  avatar           String?
  phone            String?
  description      String?
  isActive         Boolean             @default(true)
  emailVerified    Boolean             @default(false)
  isVerified       Boolean             @default(false)
  resetToken       String?
  resetExpires     DateTime?
  lastSeenAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  receivedMessages ChatMessage[]       @relation("ReceiverMessages")
  sentMessages     ChatMessage[]       @relation("SenderMessages")
  company          CompanyProfile?
  following        Follow[]            @relation("Following")
  followers        Follow[]            @relation("Followers")
  freelancer       FreelancerProfile?
  actedNotifs      Notification[]      @relation("NotificationsActed")
  notifications    Notification[]      @relation("NotificationsReceived")
  postComments     PostComment[]       @relation("PostComments")
  postLikes        PostLike[]          @relation("PostLikes")
  posts            Post[]              @relation("PostsAuthored")
  reviewsReceived  Review[]            @relation("ReviewsReceived")
  reviewsWritten   Review[]            @relation("ReviewsWritten")
  savedPosts       SavedPost[]         @relation("SavedPosts")
  stories          Story[]             @relation("StoriesAuthored")
  storyLikes       StoryLike[]         @relation("StoryLikesUser")
  storyViews       StoryView[]         @relation("StoryViews")
  subscription     StripeSubscription?
  adminRole        AdminRole           @default(USER)
  auditLogs        AuditLog[]          @relation("AdminLogs")
  boosts           Boost[]             @relation("BoostsByUser")

  @@index([role, isActive])
  @@index([adminRole])
  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  targetId  String?
  action    String
  details   Json?
  createdAt DateTime @default(now())
  admin     User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model FreelancerProfile {
  id             String            @id @default(uuid())
  userId         String            @unique
  specialties    String[]
  skills         String[]
  location       String
  hourlyRate     Decimal?          @db.Decimal(10, 2)
  rateType       RateType          @default(HOURLY)
  available      Boolean           @default(false)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedJobs   Job[]             @relation("JobsAssignedToFreelancer")
  portfolio      PortfolioItem[]
  proposals      Proposal[]        @relation("ProposalsByFreelancer")
  unavailability UnavailableDate[]

  @@index([available])
  @@index([location])
  @@map("freelancer_profiles")
}

model CompanyProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  companyName    String
  companyWebsite String?
  companySize    String?
  segment        String?
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  postedJobs     Job[]

  @@map("company_profiles")
}

model PortfolioItem {
  id           String            @id @default(uuid())
  freelancerId String
  title        String
  description  String?
  mediaType    MediaType
  url          String
  thumbnailUrl String?
  order        Int               @default(0)
  createdAt    DateTime          @default(now())
  freelancer   FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}

model UnavailableDate {
  id           String            @id @default(uuid())
  freelancerId String
  date         DateTime          @db.Date
  reason       String?
  freelancer   FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([freelancerId, date])
  @@map("unavailable_dates")
}

model Job {
  id                 String             @id @default(uuid())
  companyId          String
  title              String
  description        String
  serviceType        String
  location           String
  jobDate            DateTime           @db.Date
  jobTime            String
  budget             Decimal            @db.Decimal(10, 2)
  status             JobStatus          @default(OPEN)
  assignedTo         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  assignedFreelancer FreelancerProfile? @relation("JobsAssignedToFreelancer", fields: [assignedTo], references: [id])
  company            CompanyProfile     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  proposals          Proposal[]
  reviews            Review[]           @relation("ReviewJob")

  @@index([status])
  @@index([status, jobDate])
  @@index([companyId])
  @@index([serviceType])
  @@map("jobs")
}

model Proposal {
  id             String            @id @default(uuid())
  jobId          String
  freelancerId   String
  coverLetter    String
  proposedBudget Decimal?          @db.Decimal(10, 2)
  status         ProposalStatus    @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  freelancer     FreelancerProfile @relation("ProposalsByFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerId])
  @@index([freelancerId])
  @@index([jobId, status])
  @@map("proposals")
}

model ChatMessage {
  id              String        @id @default(uuid())
  senderId        String
  receiverId      String
  jobReference    String?
  content         String?
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  mediaType       MediaType?
  mediaUrl        String?
  mediaGroup      Json?
  storyPreviewUrl String?
  replyToId       String?
  replyTo         ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         ChatMessage[] @relation("MessageReplies")
  receiver        User          @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender          User          @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Review {
  id           String   @id @default(uuid())
  reviewerId   String
  reviewedId   String
  jobId        String
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())
  job          Job      @relation("ReviewJob", fields: [jobId], references: [id], onDelete: Cascade)
  reviewedUser User     @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewer     User     @relation("ReviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, reviewedId, jobId])
  @@map("reviews")
}

model StripeSubscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  lastChargeDate       DateTime?
  nextChargeDate       DateTime?
  planAmount           Int                @default(990)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stripe_subscriptions")
}

model Post {
  id            String         @id @default(uuid())
  authorId      String
  mediaUrl      String?
  mediaType     MediaType?
  aspectRatio   AspectRatio?   @default(LANDSCAPE)
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  thumbnailUrl  String?
  isSponsored   Boolean        @default(false)
  sponsoredCity String?
  notifications Notification[]
  comments      PostComment[]
  likes         PostLike[]
  media         PostMedia[]
  author        User           @relation("PostsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  savedBy       SavedPost[]

  @@index([authorId])
  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([isSponsored])
  @@map("posts")
}

model PostMedia {
  id           String    @id @default(uuid())
  postId       String
  mediaUrl     String
  mediaType    MediaType
  thumbnailUrl String?
  order        Int       @default(0)
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_media")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("PostLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  author    User     @relation("PostComments", fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_comments")
}

model SavedPost {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("SavedPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("saved_posts")
}

model Story {
  id            String         @id @default(uuid())
  authorId      String
  mediaUrl      String
  mediaType     MediaType
  caption       String?
  muteAudio     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  expiresAt     DateTime
  notifications Notification[]
  author        User           @relation("StoriesAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  likes         StoryLike[]
  views         StoryView[]

  @@index([authorId])
  @@index([expiresAt])
  @@map("stories")
}

model StoryLike {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation("StoryLikesUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_likes")
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer   User     @relation("StoryViews", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
  @@map("story_views")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  actorId   String
  type      NotificationType
  postId    String?
  storyId   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  actor     User             @relation("NotificationsActed", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  story     Story?           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User             @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actorId, type, postId, storyId], name: "userId_actorId_type_postId_storyId")
  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum UserRole {
  FREELANCER
  COMPANY
}

enum AdminRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  INACTIVE
}

enum MediaType {
  PHOTO
  VIDEO
}

enum AspectRatio {
  LANDSCAPE
  PORTRAIT
  SQUARE
  LANDSCAPE_43
  PORTRAIT_34
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  STORY_LIKE
  STORY_REPLY
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  NEW_PROPOSAL
}

model Boost {
  id        String      @id @default(uuid())
  userId    String
  targetId  String
  type      BoostType
  startDate DateTime    @default(now())
  endDate   DateTime
  status    BoostStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  user      User        @relation("BoostsByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, status, endDate])
  @@index([targetId, type, status])
  @@index([userId])
  @@map("boosts")
}

enum BoostType {
  PROFILE
  JOB
}

enum BoostStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum RateType {
  HOURLY
  DAILY
}
